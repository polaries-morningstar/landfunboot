# 数据库（MySQL）
DB_HOST=mysql
DB_PORT=3306
DB_NAME=landfunboot
DB_USER=root
DB_PASSWORD=your_mysql_password

# Redis（使用外部 Redis 时，REDIS_PASSWORD 必须与 Redis 实际配置的密码一致，否则登录会失败）
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password

# JWT 密钥（生产环境务必修改为随机长字符串）
JWT_SECRET=your-jwt-secret-key-at-least-32-chars

# 可选：JWT 过期秒数，默认 30 天
# JWT_EXPIRE_SECONDS=2592000

# 可选：本地存储路径（Docker 内使用）
# LANDFUN_STORAGE_LOCAL_BASE_PATH=/var/www/uploads
