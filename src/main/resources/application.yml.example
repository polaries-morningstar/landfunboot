server:
  port: 8080

spring:
  application:
    name: landfunboot
  
  datasource:
    url: jdbc:mysql://YOUR_DB_HOST:13306/landfunboot?createDatabaseIfNotExist=true&serverTimezone=Asia/Shanghai&characterEncoding=utf-8&useSSL=false
    username: YOUR_USERNAME
    password: YOUR_PASSWORD
    driver-class-name: com.mysql.cj.jdbc.Driver

  data:
    redis:
      url: redis://:YOUR_REDIS_PASSWORD@YOUR_REDIS_HOST:6379

  jackson:
    serialization:
      write-dates-as-timestamps: false

  flyway:
    enabled: true
    baseline-on-migrate: true
    repair-on-migrate: true

landfun:
  jwt:
    secret: YOUR_JWT_SECRET_KEY
    expire: 2592000

logging:
  level:
    root: INFO
    com.landfun.boot: DEBUG
    org.babyfish.jimmer.sql: INFO
